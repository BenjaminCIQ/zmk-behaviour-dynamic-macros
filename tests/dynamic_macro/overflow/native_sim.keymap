 *
 * Test: Record more events than MAX_EVENTS allows.
 *
 * Sequence:
 * 1. Start recording
 * 2. Press many keys (exceeds MAX_EVENTS)
 * 3. Verify overflow feedback/truncation
 *
 * Expected: Recording stops or truncates at MAX_EVENTS, error feedback
 *
 * Note: Default MAX_EVENTS=64, so 32 key taps = 64 events (press+release)
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/kscan_mock.h>
#include <dt-bindings/zmk/dynamic_macros.h>
#include "../behavior_keymap.dtsi"

/ {
    keymap {
        compatible = "zmk,keymap";
        default_layer {
            bindings = <
                &dm DM_REC 0
                &dm DM_STP 0
                &dm DM_SLOT_NVS 0
                &kp A
            >;
        };
    };
};

&kscan {
    events = <
        /* Start recording */
        ZMK_MOCK_PRESS(0,0,10)
        ZMK_MOCK_RELEASE(0,0,20)

        /* Press A 35 times (70 events > 64 MAX_EVENTS default) */
        ZMK_MOCK_PRESS(0,3,100)   ZMK_MOCK_RELEASE(0,3,110)
        ZMK_MOCK_PRESS(0,3,120)   ZMK_MOCK_RELEASE(0,3,130)
        ZMK_MOCK_PRESS(0,3,140)   ZMK_MOCK_RELEASE(0,3,150)
        ZMK_MOCK_PRESS(0,3,160)   ZMK_MOCK_RELEASE(0,3,170)
        ZMK_MOCK_PRESS(0,3,180)   ZMK_MOCK_RELEASE(0,3,190)
        ZMK_MOCK_PRESS(0,3,200)   ZMK_MOCK_RELEASE(0,3,210)
        ZMK_MOCK_PRESS(0,3,220)   ZMK_MOCK_RELEASE(0,3,230)
        ZMK_MOCK_PRESS(0,3,240)   ZMK_MOCK_RELEASE(0,3,250)
        ZMK_MOCK_PRESS(0,3,260)   ZMK_MOCK_RELEASE(0,3,270)
        ZMK_MOCK_PRESS(0,3,280)   ZMK_MOCK_RELEASE(0,3,290)
        ZMK_MOCK_PRESS(0,3,300)   ZMK_MOCK_RELEASE(0,3,310)
        ZMK_MOCK_PRESS(0,3,320)   ZMK_MOCK_RELEASE(0,3,330)
        ZMK_MOCK_PRESS(0,3,340)   ZMK_MOCK_RELEASE(0,3,350)
        ZMK_MOCK_PRESS(0,3,360)   ZMK_MOCK_RELEASE(0,3,370)
        ZMK_MOCK_PRESS(0,3,380)   ZMK_MOCK_RELEASE(0,3,390)
        ZMK_MOCK_PRESS(0,3,400)   ZMK_MOCK_RELEASE(0,3,410)
        ZMK_MOCK_PRESS(0,3,420)   ZMK_MOCK_RELEASE(0,3,430)
        ZMK_MOCK_PRESS(0,3,440)   ZMK_MOCK_RELEASE(0,3,450)
        ZMK_MOCK_PRESS(0,3,460)   ZMK_MOCK_RELEASE(0,3,470)
        ZMK_MOCK_PRESS(0,3,480)   ZMK_MOCK_RELEASE(0,3,490)
        ZMK_MOCK_PRESS(0,3,500)   ZMK_MOCK_RELEASE(0,3,510)
        ZMK_MOCK_PRESS(0,3,520)   ZMK_MOCK_RELEASE(0,3,530)
        ZMK_MOCK_PRESS(0,3,540)   ZMK_MOCK_RELEASE(0,3,550)
        ZMK_MOCK_PRESS(0,3,560)   ZMK_MOCK_RELEASE(0,3,570)
        ZMK_MOCK_PRESS(0,3,580)   ZMK_MOCK_RELEASE(0,3,590)
        ZMK_MOCK_PRESS(0,3,600)   ZMK_MOCK_RELEASE(0,3,610)
        ZMK_MOCK_PRESS(0,3,620)   ZMK_MOCK_RELEASE(0,3,630)
        ZMK_MOCK_PRESS(0,3,640)   ZMK_MOCK_RELEASE(0,3,650)
        ZMK_MOCK_PRESS(0,3,660)   ZMK_MOCK_RELEASE(0,3,670)
        ZMK_MOCK_PRESS(0,3,680)   ZMK_MOCK_RELEASE(0,3,690)
        ZMK_MOCK_PRESS(0,3,700)   ZMK_MOCK_RELEASE(0,3,710)
        ZMK_MOCK_PRESS(0,3,720)   ZMK_MOCK_RELEASE(0,3,730)
        ZMK_MOCK_PRESS(0,3,740)   ZMK_MOCK_RELEASE(0,3,750)
        ZMK_MOCK_PRESS(0,3,760)   ZMK_MOCK_RELEASE(0,3,770)
        ZMK_MOCK_PRESS(0,3,780)   ZMK_MOCK_RELEASE(0,3,790)

        /* Stop recording */
        ZMK_MOCK_PRESS(0,1,1000)
        ZMK_MOCK_RELEASE(0,1,1010)
    >;
};
