 *
 * Test: Record a key sequence and play it back from NVS slot.
 *
 * Sequence:
 * 1. Press REC to start recording
 * 2. Press A, B, C
 * 3. Press STP to stop recording
 * 4. Press slot 0 to assign recording
 * 5. Press slot 0 again to playback
 *
 * Expected: Playback emits A, B, C key events
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/kscan_mock.h>
#include <dt-bindings/zmk/dynamic_macros.h>
#include "../behavior_keymap.dtsi"

/ {
    keymap {
        compatible = "zmk,keymap";
        default_layer {
            bindings = <
                &dm DM_REC 0        /* 0,0: start recording */
                &dm DM_STP 0        /* 0,1: stop recording */
                &dm DM_SLOT_NVS 0   /* 0,2: NVS slot 0 (assign/play) */
                &kp A               /* 0,3: key A */
                &kp B               /* 1,0: key B */
                &kp C               /* 1,1: key C */
            >;
        };
    };
};

&kscan {
    events = <
        /* Start recording */
        ZMK_MOCK_PRESS(0,0,10)
        ZMK_MOCK_RELEASE(0,0,20)

        /* Record: A B C */
        ZMK_MOCK_PRESS(0,3,100)
        ZMK_MOCK_RELEASE(0,3,150)
        ZMK_MOCK_PRESS(1,0,200)
        ZMK_MOCK_RELEASE(1,0,250)
        ZMK_MOCK_PRESS(1,1,300)
        ZMK_MOCK_RELEASE(1,1,350)

        /* Stop recording */
        ZMK_MOCK_PRESS(0,1,400)
        ZMK_MOCK_RELEASE(0,1,410)

        /* Assign to slot 0 */
        ZMK_MOCK_PRESS(0,2,500)
        ZMK_MOCK_RELEASE(0,2,510)

        /* Wait for feedback typing to complete, then playback */
        ZMK_MOCK_PRESS(0,2,2000)
        ZMK_MOCK_RELEASE(0,2,2010)
    >;
};
