 *
 * Test: Record macro, save, then delete it.
 *
 * Sequence:
 * 1. Record A, save to slot 0
 * 2. Play slot 0 (should work)
 * 3. Press DEL to enter delete mode
 * 4. Press slot 0 to delete
 * 5. Play slot 0 again (should be empty)
 *
 * Expected: First playback works, second fails (empty)
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/kscan_mock.h>
#include <dt-bindings/zmk/dynamic_macros.h>
#include "../behavior_keymap.dtsi"

/ {
    keymap {
        compatible = "zmk,keymap";
        default_layer {
            bindings = <
                &dm DM_REC 0
                &dm DM_STP 0
                &dm DM_SLOT_NVS 0
                &dm DM_DEL 0
                &kp A
            >;
        };
    };
};

&kscan {
    events = <
        /* Record A */
        ZMK_MOCK_PRESS(0,0,10)
        ZMK_MOCK_RELEASE(0,0,20)
        ZMK_MOCK_PRESS(0,4,100)
        ZMK_MOCK_RELEASE(0,4,150)
        ZMK_MOCK_PRESS(0,1,200)
        ZMK_MOCK_RELEASE(0,1,210)

        /* Assign to slot 0 */
        ZMK_MOCK_PRESS(0,2,300)
        ZMK_MOCK_RELEASE(0,2,310)

        /* Play slot 0 - should emit A */
        ZMK_MOCK_PRESS(0,2,2000)
        ZMK_MOCK_RELEASE(0,2,2010)

        /* Enter delete mode */
        ZMK_MOCK_PRESS(0,3,3000)
        ZMK_MOCK_RELEASE(0,3,3010)

        /* Delete slot 0 */
        ZMK_MOCK_PRESS(0,2,3100)
        ZMK_MOCK_RELEASE(0,2,3110)

        /* Try play slot 0 - should be empty now */
        ZMK_MOCK_PRESS(0,2,5000)
        ZMK_MOCK_RELEASE(0,2,5010)
    >;
};
