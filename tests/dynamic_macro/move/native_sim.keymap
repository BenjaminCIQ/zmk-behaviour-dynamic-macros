 *
 * Test: Move macro from one slot to another.
 *
 * Sequence:
 * 1. Record A, save to slot 0
 * 2. Press MOV to enter move mode
 * 3. Press slot 0 (source)
 * 4. Press slot 1 (destination)
 * 5. Play slot 0 (should be empty)
 * 6. Play slot 1 (should emit A)
 *
 * Expected: Macro moved from slot 0 to slot 1
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/kscan_mock.h>
#include <dt-bindings/zmk/dynamic_macros.h>
#include "../behavior_keymap.dtsi"

/ {
    keymap {
        compatible = "zmk,keymap";
        default_layer {
            bindings = <
                &dm DM_REC 0
                &dm DM_STP 0
                &dm DM_SLOT_NVS 0
                &dm DM_SLOT_NVS 1
                &dm DM_MOV 0
                &kp A
            >;
        };
    };
};

&kscan {
    events = <
        /* Record A */
        ZMK_MOCK_PRESS(0,0,10)
        ZMK_MOCK_RELEASE(0,0,20)
        ZMK_MOCK_PRESS(0,5,100)
        ZMK_MOCK_RELEASE(0,5,150)
        ZMK_MOCK_PRESS(0,1,200)
        ZMK_MOCK_RELEASE(0,1,210)

        /* Assign to slot 0 */
        ZMK_MOCK_PRESS(0,2,300)
        ZMK_MOCK_RELEASE(0,2,310)

        /* Enter move mode */
        ZMK_MOCK_PRESS(0,4,2000)
        ZMK_MOCK_RELEASE(0,4,2010)

        /* Select source: slot 0 */
        ZMK_MOCK_PRESS(0,2,2100)
        ZMK_MOCK_RELEASE(0,2,2110)

        /* Select destination: slot 1 */
        ZMK_MOCK_PRESS(0,3,2200)
        ZMK_MOCK_RELEASE(0,3,2210)

        /* Play slot 0 - should be empty */
        ZMK_MOCK_PRESS(0,2,4000)
        ZMK_MOCK_RELEASE(0,2,4010)

        /* Play slot 1 - should emit A */
        ZMK_MOCK_PRESS(0,3,5000)
        ZMK_MOCK_RELEASE(0,3,5010)
    >;
};
