 *
 * Test: Record then let assign timeout expire without saving.
 *
 * Sequence:
 * 1. Press REC to start recording
 * 2. Press A
 * 3. Press STP to stop recording
 * 4. Wait for ASSIGN_TIMEOUT (default 10s) without pressing slot
 *
 * Expected: Recording discarded, state returns to IDLE
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/kscan_mock.h>
#include <dt-bindings/zmk/dynamic_macros.h>
#include "../behavior_keymap.dtsi"

/ {
    keymap {
        compatible = "zmk,keymap";
        default_layer {
            bindings = <
                &dm DM_REC 0
                &dm DM_STP 0
                &dm DM_SLOT_NVS 0
                &kp A
            >;
        };
    };
};

&kscan {
    events = <
        /* Start recording */
        ZMK_MOCK_PRESS(0,0,10)
        ZMK_MOCK_RELEASE(0,0,20)

        /* Record: A */
        ZMK_MOCK_PRESS(0,3,100)
        ZMK_MOCK_RELEASE(0,3,150)

        /* Stop recording */
        ZMK_MOCK_PRESS(0,1,200)
        ZMK_MOCK_RELEASE(0,1,210)

        /* Wait for timeout (10s+) then try to play - should be empty */
        ZMK_MOCK_PRESS(0,2,15000)
        ZMK_MOCK_RELEASE(0,2,15010)
    >;
};
